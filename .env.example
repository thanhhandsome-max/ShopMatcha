# Copy to `.env` / `.env.local`. Không commit `.env`.
#
# Dự án chạy một process Next.js; API nằm trong Route Handlers (/api/*).

# SQL Server — Prisma (schema web_matcha)
DATABASE_URL="sqlserver://HOST;database=web_matcha;user=sa;password=Thanh@123;encrypt=false"

# JWT (đổi trong production)
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-refresh

# Cửa hàng khi đối chiếu tồn kho giỏ hàng
CART_STORE_MA_CH=CH001

# Trống = dùng API cùng origin Next (/api). Chỉ set nếu tách API ra host khác.
# NEXT_PUBLIC_API_URL=http://localhost:3000/api
