generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model chitietdonhang {
  MaSP     String   @db.VarChar(20)
  MaDH     String   @map("MaHD") @db.VarChar(20)
  SoLuong  Int
  DonGia   Decimal  @db.Decimal(15, 2)
  TongTien Decimal  @map("ThanhTien") @db.Decimal(15, 2)
  sanpham  sanpham  @relation("CTDH_SanPham", fields: [MaSP], references: [MaSP], onUpdate: NoAction, map: "chitietdonhang_ibfk_1")
  donhang  donhang  @relation("CTDH_DonHang", fields: [MaDH], references: [MaDH], onUpdate: NoAction, map: "chitietdonhang_ibfk_2")

  @@id([MaSP, MaDH])
  @@index([MaDH], map: "MaDH")
  @@map("chitiethoadon")
}

model chitietphieuchuyenhang {
  MaPC            String          @db.VarChar(20)
  MaSp            String          @db.VarChar(20)
  SoLuong         Int             @default(0)
  TongTien        Decimal?        @db.Decimal(15, 2)
  phieuchuyenhang phieuchuyenhang @relation("CTPC_PhieuChuyen", fields: [MaPC], references: [MaPC], onUpdate: NoAction, map: "FK_CTPC_PhieuChuyen")
  sanpham         sanpham         @relation("CTPC_SanPham", fields: [MaSp], references: [MaSP], onUpdate: NoAction, map: "FK_CTPC_SanPham")

  @@id([MaPC, MaSp])
  @@index([MaSp], map: "FK_CTPC_SanPham")
}

model chitietphieunhanhang {
  MaPNH         String        @db.VarChar(20)
  MaSp          String        @db.VarChar(20)
  SoLuong       Int           @default(0)
  TongTien      Decimal?      @db.Decimal(15, 2)
  phieunhanhang phieunhanhang @relation("CTPNH_PhieuNhan", fields: [MaPNH], references: [MaPNH], onUpdate: NoAction, map: "FK_CTPNH_PhieuNhan")
  sanpham       sanpham       @relation("CTPNH_SanPham", fields: [MaSp], references: [MaSP], onUpdate: NoAction, map: "FK_CTPNH_SanPham")

  @@id([MaPNH, MaSp])
  @@index([MaSp], map: "FK_CTPNH_SanPham")
}

model chitietphieunhap {
  MaPN      String    @db.VarChar(20)
  MaSP      String    @db.VarChar(20)
  SoLuong   Int       @default(0)
  TongTien  Decimal?  @db.Decimal(15, 2)
  phieunhap phieunhap @relation("CTPN_PhieuNhap", fields: [MaPN], references: [MaPN], map: "FK_CTPN_PhieuNhap")
  sanpham   sanpham   @relation("CTPN_SanPham", fields: [MaSP], references: [MaSP], map: "FK_CTPN_SanPham")

  @@id([MaPN, MaSP])
  @@index([MaSP], map: "FK_CTPN_SanPham")
}

model chitietphieuxuat {
  MaPX      String    @db.VarChar(20)
  MaSP      String    @db.VarChar(20)
  SoLuong   Int?
  phieuxuat phieuxuat @relation("CTPX_PhieuXuat", fields: [MaPX], references: [MaPX], onDelete: Cascade, map: "chitietphieuxuat_ibfk_1")
  sanpham   sanpham   @relation("CTPX_SanPham", fields: [MaSP], references: [MaSP], map: "chitietphieuxuat_ibfk_2")

  @@id([MaPX, MaSP])
  @@index([MaSP], map: "chitietphieuxuat_ibfk_2")
}

model chuyenhangthanhpham {
  MaHD           String    @id @db.VarChar(20)
  MaVanDon       String?   @db.VarChar(100)
  DonViVanChuyen String?   @db.VarChar(100)
  NgayGui        DateTime?
  NgayDuKien     DateTime?
  NgayNhan       DateTime?
  TrangThai      Int?      @default(0)
  GhiChu         String?   @db.Text
  donhang        donhang   @relation("CHT_DonHang", fields: [MaHD], references: [MaDH], onDelete: Cascade, map: "FK_GiaoHang_HoaDon")

  @@map("chuyenhanhthanhpham")
}

model cuahang {
  MaCH                 String            @id @db.VarChar(20)
  TenCH                String            @db.VarChar(100)
  DiaChi               String?           @db.VarChar(255)
  SDT                  String?           @db.VarChar(15)
  donhang              donhang[]
  khuyenmai            khuyenmai[]
  nhanvien             nhanvien[]
  phieuchuyenhang_nhan phieuchuyenhang[] @relation("CuaHangNhan")
  phieuchuyenhang_xuat phieuchuyenhang[] @relation("CuaHangXuat")
  phieuxuat            phieuxuat[]
}

model donhang {
  MaDH                String               @id @map("MaHD") @db.VarChar(20)
  MaCH                String?              @map("MaCuahang") @db.VarChar(20)
  MaNV                String?              @db.VarChar(20)
  MaKH                String?              @map("Makh") @db.VarChar(20)
  Makmkh              String?              @db.VarChar(20)
  order_code          String?              @unique @db.VarChar(50)
  order_type          Int?                 @default(1)
  TongTien            Decimal?             @default(0.00) @db.Decimal(15, 2)
  subtotal            Decimal?             @default(0.00) @db.Decimal(15, 2)
  shipping_fee        Decimal?             @default(0.00) @db.Decimal(15, 2)
  TrangThai           Int?                 @default(1)
  payment_status      Int?                 @default(0)
  payment_method      String?              @db.VarChar(50)
  address_id          String?              @db.VarChar(50)
  customer_note       String?              @db.Text
  NgayTao             DateTime?            @default(now()) 
  chitietdonhang      chitietdonhang[]     @relation("CTDH_DonHang")
  chuyenhangthanhpham chuyenhangthanhpham? @relation("CHT_DonHang")
  cuahang             cuahang?             @relation(fields: [MaCH], references: [MaCH], onDelete: NoAction, onUpdate: NoAction, map: "FK_HD_CuaHang")
  khuyenmaikhachhang  khuyenmaikhachhang?  @relation("HD_KMKH", fields: [Makmkh], references: [Makmkh], onDelete: NoAction, onUpdate: NoAction, map: "FK_HD_KMKH")
  khachhang           khachhang?           @relation(fields: [MaKH], references: [MaKH], onDelete: NoAction, onUpdate: NoAction, map: "FK_HD_KhachHang")
  nhanvien            nhanvien?            @relation(fields: [MaNV], references: [MaNV], onDelete: NoAction, onUpdate: NoAction, map: "FK_HD_NhanVien")
  // taikhoan relation removed: hoadon table does not contain an account FK
  payments            payments[]

  @@index([MaCH], map: "FK_HD_CuaHang")
  @@index([MaNV], map: "FK_HD_NhanVien")
  @@index([MaKH], map: "FK_HD_KhachHang")
  @@index([Makmkh], map: "FK_HD_KMKH")
  @@map("hoadon")
  
  @@index([order_code], map: "order_code")
}

model khachhang {
  MaKH               String               @id @db.VarChar(20)
  TenKH              String               @db.VarChar(255)
  SDT                String?              @db.VarChar(20)
  NgaySinh           DateTime?            @db.Date
  GioiTinh           String?              @db.VarChar(10)
  DiaChi             String?              @db.VarChar(255)
  Email              String?              @unique @db.VarChar(100)
  NgayTao            DateTime?            @default(now()) 
  TrangThai          Int?                 @default(1)
  address            address[]
  donhang            donhang[]
  khuyenmaikhachhang khuyenmaikhachhang[]

  @@index([Email], map: "Email")
}

model kho {
  MaKho       String     @id @db.VarChar(20)
  TenKho      String     @db.VarChar(100)
  DiaChi      String?    @db.VarChar(255)
  SoDienThoai String?    @db.VarChar(20)
  TrangThai   Int?       @default(1)
  nhanvien    nhanvien[]
  tonkho      tonkho[]
}

model loaisanpham {
  MaLoai    String    @id @db.VarChar(20)
  TenLoai   String    @db.VarChar(100)
  Mota      String?   @db.Text
  TrangThai Int?      @default(1)
  sanpham   sanpham[]
}

model nhanvien {
  MaNV          String          @id @db.VarChar(20)
  HoTen         String          @db.VarChar(100)
  NgayNhanChuc  DateTime?       @db.Date
  TrangThai     String?         @db.VarChar(50)
  DiaChi        String?         @db.VarChar(255)
  SDT           String?         @db.VarChar(15)
  LuongNen      Decimal?        @db.Decimal(15, 2)
  Email         String?         @unique @db.VarChar(100)
  MaCH          String?         @db.VarChar(20)
  MaKho         String?         @db.VarChar(20)
  MaTaiKhoan    String?         @db.VarChar(20)
  donhang       donhang[]
  cuahang       cuahang?        @relation(fields: [MaCH], references: [MaCH], onDelete: NoAction, onUpdate: NoAction, map: "nhanvien_ibfk_1")
  kho           kho?            @relation(fields: [MaKho], references: [MaKho], onDelete: NoAction, onUpdate: NoAction, map: "nhanvien_ibfk_2")
  taikhoan      taikhoan?       @relation("NV_TaiKhoan", fields: [MaTaiKhoan], references: [MaTaiKhoan], onDelete: NoAction, onUpdate: NoAction, map: "nhanvien_ibfk_3")
  phieunhanhang phieunhanhang[] @relation("PNH_NhanVien")
  phieunhap     phieunhap[]     @relation("PN_NhanVien")
  phieuxuat     phieuxuat[]

  @@index([MaCH], map: "nhanvien_ibfk_1")
  @@index([MaKho], map: "nhanvien_ibfk_2")
  @@index([MaTaiKhoan], map: "nhanvien_ibfk_3")
  @@index([Email], map: "Email")
}

model nhaphanphoi {
  MaNPP     String      @id @db.VarChar(20)
  TenNPP    String      @db.VarChar(255)
  DiaChi    String?     @db.VarChar(255)
  Sdt       String?     @db.VarChar(20)
  phieunhap phieunhap[]
}

model payments {
  payment_id       String         @id @db.VarChar(20)
  MaHD             String         @db.VarChar(20)
  transaction_id   String?        @db.VarChar(100)
  amount           Decimal        @db.Decimal(15, 2)
  currency         String?        @default("VND") @db.VarChar(10)
  payment_method   String?        @db.VarChar(50)
  payment_endpoint String?        @db.VarChar(255)
  status           Int?           @default(0)
  paid_at          DateTime?
  note             String?        @db.Text
  payment_logs     payment_logs[]
  donhang          donhang        @relation(fields: [MaHD], references: [MaDH], onDelete: Cascade, map: "FK_Payments_HoaDon")

  @@index([MaHD], map: "FK_Payments_HoaDon")
}

model payment_logs {
  Payment_Logs_id Int       @id @default(autoincrement())
  payment_id      String?   @db.VarChar(20)
  log_type        String?   @db.VarChar(50)
  vnp_TxnRef      String?   @db.VarChar(100)
  response_code   String?   @db.VarChar(10)
  message         String?   @db.Text
  new_data        String?   @db.Text
  created_at      DateTime? @default(now())
  payments        payments? @relation(fields: [payment_id], references: [payment_id], onDelete: Cascade, map: "FK_Logs_Payments")

  @@index([payment_id], map: "FK_Logs_Payments")
}

model phanquyen {
  MaTK     String    @db.VarChar(20)
  MaVaiTro String    @db.VarChar(20)
  taikhoan taikhoan  @relation("PQ_TaiKhoan", fields: [MaTK], references: [MaTaiKhoan], onDelete: Cascade, map: "FK_PQ_TaiKhoan")
  vaitro   vaitro    @relation("PQ_VaiTro", fields: [MaVaiTro], references: [MaVaiTro], onDelete: Cascade, map: "FK_PQ_VaiTro2")

  @@id([MaTK, MaVaiTro])
  @@index([MaTK], map: "FK_PQ_TaiKhoan")
  @@index([MaVaiTro], map: "FK_PQ_VaiTro")
}

model phieuchuyenhang {
  MaPC                   String                   @id @db.VarChar(20)
  MaCH_Xuat              String?                  @db.VarChar(20)
  MaCH_Nhan              String?                  @db.VarChar(20)
  TongTien               Decimal?                 @default(0.00) @db.Decimal(15, 2)
  NgayTao                DateTime?                @default(now()) 
  trangthai              Int?                     @default(0)
  chitietphieuchuyenhang chitietphieuchuyenhang[] @relation("CTPC_PhieuChuyen")
  cuahang_nhan           cuahang?                 @relation("CuaHangNhan", fields: [MaCH_Nhan], references: [MaCH], onDelete: NoAction, onUpdate: NoAction, map: "FK_PC_CuaHangNhan")
  cuahang_xuat           cuahang?                 @relation("CuaHangXuat", fields: [MaCH_Xuat], references: [MaCH], onDelete: NoAction, onUpdate: NoAction, map: "FK_PC_CuaHangXuat")
  phieunhanhang          phieunhanhang?           @relation("PNH_PhieuChuyen")

  @@index([MaCH_Nhan], map: "FK_PC_CuaHangNhan")
  @@index([MaCH_Xuat], map: "FK_PC_CuaHangXuat")
}

model phieunhanhang {
  MaPNH                String                 @id @db.VarChar(20)
  MaPC                 String?                @unique @db.VarChar(20)
  MaNV                 String?                @db.VarChar(20)
  MaTaiKhoan           String?                @db.VarChar(20)
  TongTien             Decimal?               @default(0.00) @db.Decimal(15, 2)
  NgayTao              DateTime?              @default(now()) 
  trangthai            Int?                   @default(1)
  chitietphieunhanhang chitietphieunhanhang[] @relation("CTPNH_PhieuNhan")
  nhanvien             nhanvien?              @relation("PNH_NhanVien", fields: [MaNV], references: [MaNV], onDelete: NoAction, onUpdate: NoAction, map: "FK_PNH_NhanVien")
  phieuchuyenhang      phieuchuyenhang?       @relation("PNH_PhieuChuyen", fields: [MaPC], references: [MaPC], onDelete: NoAction, onUpdate: NoAction, map: "FK_PNH_PhieuChuyen")
  taikhoan             taikhoan?              @relation("PNH_TaiKhoan", fields: [MaTaiKhoan], references: [MaTaiKhoan], onDelete: NoAction, onUpdate: NoAction, map: "FK_PNH_TaiKhoan")

  @@index([MaNV], map: "FK_PNH_NhanVien")
  @@index([MaTaiKhoan], map: "FK_PNH_TaiKhoan")
}

model phieunhap {
  MaPN             String             @id @db.VarChar(20)
  MaNPP            String?            @db.VarChar(20)
  MaNV             String?            @db.VarChar(20)
  TongTien         Decimal?           @default(0.00) @db.Decimal(15, 2)
  NgayTao          DateTime?          @default(now()) 
  TrangThai        Int?               @default(1)
  MaTaiKhoan       String?            @db.VarChar(20)
  chitietphieunhap chitietphieunhap[] @relation("CTPN_PhieuNhap")
  nhaphanphoi      nhaphanphoi?       @relation(fields: [MaNPP], references: [MaNPP], map: "FK_PN_NhaPhanPhoi")
  nhanvien         nhanvien?          @relation("PN_NhanVien", fields: [MaNV], references: [MaNV], map: "FK_PN_NhanVien")
  taikhoan         taikhoan?          @relation("PN_TaiKhoan", fields: [MaTaiKhoan], references: [MaTaiKhoan], onDelete: NoAction, onUpdate: NoAction, map: "FK_PN_TaiKhoan")

  @@index([MaNPP], map: "FK_PN_NhaPhanPhoi")
  @@index([MaNV], map: "FK_PN_NhanVien")
  @@index([MaTaiKhoan], map: "FK_PN_TaiKhoan")
}

model phieuxuat {
  MaPX             String             @id @db.VarChar(20)
  NgayTao          DateTime?          @default(now()) @db.DateTime
  TongTien         Decimal?           @default(0.00) @db.Decimal(18, 2)
  TrangThai        Int?               @default(1)
  MaNV             String?            @db.VarChar(20)
  MaCH             String?            @db.VarChar(20)
  MaTaiKhoan       String?            @db.VarChar(20)
  chitietphieuxuat chitietphieuxuat[] @relation("CTPX_PhieuXuat")
  cuahang          cuahang?           @relation(fields: [MaCH], references: [MaCH], onDelete: NoAction, onUpdate: NoAction, map: "FK_MaCH")
  nhanvien         nhanvien?          @relation(fields: [MaNV], references: [MaNV], onDelete: NoAction, onUpdate: NoAction, map: "FK_MaNV")
  taikhoan         taikhoan?          @relation("PX_TaiKhoan", fields: [MaTaiKhoan], references: [MaTaiKhoan], onDelete: NoAction, onUpdate: NoAction, map: "FK_PX_TaiKhoan2")

  @@index([MaNV], map: "FK_MaNV")
  @@index([MaCH], map: "FK_MaCH")
  @@index([MaTaiKhoan], map: "FK_PX_TaiKhoan2")
}

model sanpham {
  MaSP                   String                   @id @db.VarChar(20)
  TenSP                  String                   @map("TenSanPham") @db.VarChar(255)
  MaCodeSp               String?                  @unique @db.VarChar(50)
  GiaVon                 Decimal?                 @default(0.00) @db.Decimal(18, 2)
  GiaBan                 Decimal?                 @default(0.00) @db.Decimal(18, 2)
  Mota                   String?                  @map("MoTa") @db.Text
  TrangThai              Int?                     @default(1) @db.TinyInt
  MaLoai                 String?                  @db.VarChar(20)
  NgayTao                DateTime?                @default(now()) 
  chitietdonhang         chitietdonhang[]         @relation("CTDH_SanPham")
  chitietphieuchuyenhang chitietphieuchuyenhang[] @relation("CTPC_SanPham")
  chitietphieunhanhang   chitietphieunhanhang[]   @relation("CTPNH_SanPham")
  chitietphieunhap       chitietphieunhap[]       @relation("CTPN_SanPham")
  chitietphieuxuat       chitietphieuxuat[]       @relation("CTPX_SanPham")
  khuyenmai              khuyenmai[]
  loaisanpham            loaisanpham?             @relation(fields: [MaLoai], references: [MaLoai], onDelete: NoAction, onUpdate: NoAction, map: "FK_SanPham_Loai")
  sanpham_anh            sanpham_anh[]
  tonkho                 tonkho[]

  @@index([MaLoai], map: "FK_SanPham_Loai")
  @@index([MaCodeSp], map: "MaCodeSp")
}

model taikhoan {
  MaTaiKhoan    String          @id @map("MaTK") @db.VarChar(20)
  TenDangNhap   String          @unique(map: "TenDangNhap") @db.VarChar(50)
  MatKhau       String          @db.VarChar(255)
  TrangThai     Int?            @default(1)
  // donhang relation removed: hoadon table has no account FK
  nhanvien      nhanvien[]      @relation("NV_TaiKhoan")
  phanquyen     phanquyen[]     @relation("PQ_TaiKhoan")
  phieunhanhang phieunhanhang[] @relation("PNH_TaiKhoan")
  phieunhap     phieunhap[]     @relation("PN_TaiKhoan")
  phieuxuat     phieuxuat[]     @relation("PX_TaiKhoan")
}

model CartItems {
  Cartid    Int       @id @default(autoincrement())
  MaKH      String    @db.NVarChar(255)
  MaCH      String    @db.NVarChar(255)
  MaSp      String    @db.NVarChar(255)
  name      String    @db.NVarChar(255)
  price     Decimal   @db.Decimal(18, 2)
  image     String?   @db.NVarChar(255)
  quantity  Int
  createdAt DateTime? @default(now()) @db.DateTime
  updatedAt DateTime? @db.DateTime
}

model tonkho {
  MaKho       String    @db.VarChar(20)
  MaSP        String    @db.VarChar(20)
  SoLuong     Int?      @default(0)
  NgayCapNhat DateTime? @default(now()) 
  kho         kho       @relation(fields: [MaKho], references: [MaKho], onDelete: Cascade, onUpdate: NoAction, map: "FK_TonKho_Kho")
  sanpham     sanpham   @relation(fields: [MaSP], references: [MaSP], onDelete: Cascade, onUpdate: NoAction, map: "FK_TonKho_SanPham")

  @@id([MaKho, MaSP])
  @@index([MaSP], map: "FK_TonKho_SanPham")
  @@index([MaKho], map: "FK_TonKho_Kho")
}

model vaitro {
  MaVaiTro  String      @id @db.VarChar(20)
  TenVaiTro String      @db.VarChar(100)
  phanquyen phanquyen[] @relation("PQ_VaiTro")
}

model address {
  address_id   String    @id @db.VarChar(20)
  Makh         String    @db.VarChar(20)
  ten          String?   @db.VarChar(100)
  Sdt          String?   @db.VarChar(20)
  tinhthanhpho String?   @db.VarChar(100)
  quanhuyen    String?   @db.VarChar(100)
  coinh        String?   @db.VarChar(255)
  khachhang    khachhang @relation(fields: [Makh], references: [MaKH], onDelete: Cascade, map: "FK_Address_KhachHang")

  @@index([Makh], map: "FK_Address_KhachHang")
}

model sanpham_anh {
  MaAnh       String  @id @db.VarChar(20)
  MaSP        String  @db.VarChar(20)
  DuongDanAnh String  @db.VarChar(255)
  ThuTu       Int?    @default(0)
  AnhChinh    Int?    @default(0)
  sanpham     sanpham @relation(fields: [MaSP], references: [MaSP], onDelete: Cascade, map: "FK_Anh_SanPham")

  @@index([MaSP], map: "FK_Anh_SanPham")
}

model khuyenmai {
  Makhuyenmai String    @id @db.VarChar(20)
  MaCH        String?   @db.VarChar(20)
  Masp        String?   @db.VarChar(20)
  mota        String?   @db.Text
  giatri      Decimal?  @default(0.00) @db.Decimal(15, 2)
  thoihan     DateTime?
  cuahang     cuahang?  @relation(fields: [MaCH], references: [MaCH], map: "FK_KM_CuaHang")
  sanpham     sanpham?  @relation(fields: [Masp], references: [MaSP], map: "FK_KM_SanPham")

  @@index([MaCH], map: "FK_KM_CuaHang")
  @@index([Masp], map: "FK_KM_SanPham")
}

model khuyenmaikhachhang {
  Makmkh    String    @id @db.VarChar(20)
  MaKH      String    @db.VarChar(20)
  giatri    Decimal?  @default(0.00) @db.Decimal(15, 2)
  thoihan   DateTime?
  mota      String?   @db.Text
  Uutien    Int?      @default(0)
  donhang   donhang[] @relation("HD_KMKH")
  khachhang khachhang @relation(fields: [MaKH], references: [MaKH], onDelete: Cascade, map: "FK_KMKH_KhachHang")

  @@index([MaKH], map: "FK_KMKH_KhachHang")
}

